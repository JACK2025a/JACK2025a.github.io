        // Phase 1 按钮处理
        DOM.p1MasterBtn.onclick = () => {
            if (isKillButtonLocked) {
                showToast("Kill 按钮冷却中 (0.5s)，请勿连击。");
                return;
            }
            if (currentWord) {
                isKillButtonLocked = true;
                DOM.p1MasterBtn.disabled = true;
                setTimeout(() => {
                    isKillButtonLocked = false;
                    DOM.p1MasterBtn.disabled = false;
                    if (currentPhase === 'phase-1') updateStudyUI('phase-1'); 
                }, 500); 

                updateSRS(currentWord, 5);
                saveToLocalStorage();
                goToNextWord();
                showToast(`"${currentWord.word}" 已永久标熟，不再出现！`);
            }
        };
        
        document.getElementById('p1-know-btn').onclick = () => {
             if (currentWord) {
                 switchPhase('phase-2');
             }
        };
        
        document.getElementById('p1-dont-know-btn').onclick = () => {
            if (currentWord) {
                currentWord.correctCount = 0;
                updateSRS(currentWord, 0); 
                saveToLocalStorage();
                switchPhase('full-card');
            }
        };

        function handleQuizAnswer(event) {
            const clickedButton = event.target.closest('.quiz-option');
            const isCorrect = clickedButton.dataset.correct === 'true';

            document.querySelectorAll('.quiz-option').forEach(btn => btn.style.pointerEvents = 'none');
            
            const correctButton = Array.from(document.querySelectorAll('.quiz-option')).find(btn => btn.dataset.correct === 'true');
            
            if(correctButton) {
                correctButton.classList.add('quiz-correct');
            }
            if (!isCorrect) {
                clickedButton.classList.add('quiz-wrong');
            }


            setTimeout(() => {
                if (isCorrect) {
                    currentWord.correctCount++;
                    if (currentWord.correctCount >= 2) {
                        switchPhase('full-card');
                    } else {
                        updateSRS(currentWord, 3); 
                        saveToLocalStorage();
                        goToNextWord(); 
                        showToast("正确！距离掌握更进一步。");
                    }
                } else {
                    // V4.0: 答错后直接下一个词
                    currentWord.correctCount = 0;
                    updateSRS(currentWord, 0); 
                    saveToLocalStorage();
                    
                    const correctMeaningText = correctButton ? correctButton.textContent.substring(3).trim() : 'N/A';
                    showToast(`错误！正确答案是：${correctMeaningText}。已重新加入复习队列。`);
                    
                    goToNextWord(); 
                }
                
                // 清除样式
                document.querySelectorAll('.quiz-option').forEach(btn => {
                    btn.classList.remove('quiz-correct', 'quiz-wrong');
                });
            }, 1000); 
        }

        // Phase 3 按钮处理
        // DOM.nextWordBtn.onclick 在 updateStudyUI('full-card') 时绑定

        document.getElementById('p3-master-btn').onclick = () => {
            updateSRS(currentWord, 5); 
            saveToLocalStorage();
            goToNextWord();
            showToast("恭喜！单词已掌握。");
        };

        document.getElementById('p3-loop-btn').onclick = () => {
            currentWord.correctCount = 0;
            updateSRS(currentWord, 1);
            saveToLocalStorage();
            goToNextWord();
            showToast("单词已重新加入学习队列。");
        };
        
        // --- 8. 全局键盘事件绑定 ---
        document.addEventListener('keydown', handleGlobalKeyPress);


        // --- 9. 悬停查询功能实现 (不变) ---

        let pressTimer;
        const pressDuration = 500; 

        function showHoverMeaning(wordData) {
            document.getElementById('hover-word').textContent = wordData.word;
            document.getElementById('hover-meaning-text').textContent = wordData.meaning;
            document.getElementById('hover-examples-text').textContent = `例句: ${wordData.example_en}`;
            DOM.hoverMeaning.classList.add('show');
            DOM.hoverMeaning.classList.remove('hidden');
        }

        function hideHoverMeaning() {
            DOM.hoverMeaning.classList.remove('show');
            setTimeout(() => DOM.hoverMeaning.classList.add('hidden'), 300);
        }

        document.addEventListener('mouseover', handleMouseOver);
        document.addEventListener('mouseout', handleMouseOut);

        function handleMouseOver(e) {
            if (e.target.closest('#p1-word-text') && currentWord) {
                showHoverMeaning(currentWord);
            }
        }

        function handleMouseOut(e) {
            if (e.target.closest('#p1-word-text')) {
                hideHoverMeaning();
            }
        }

        document.addEventListener('mousedown', handlePressStart);
        document.addEventListener('mouseup', handlePressEnd);
        document.addEventListener('touchstart', (e) => handlePressStart(e.touches[0]));
        document.addEventListener('touchend', handlePressEnd);


        function handlePressStart(e) {
            if (e.button !== 0 && e.type === 'mousedown') return; 

            if (e.target.closest('#p1-word-text')) {
                clearTimeout(pressTimer);
                pressTimer = setTimeout(() => {
                    if (currentWord) {
                        showHoverMeaning(currentWord);
                    }
                }, pressDuration);
            }
        }

        function handlePressEnd(e) {
            clearTimeout(pressTimer);
            if (e.type === 'mouseup' || e.type === 'touchend') { 
                hideHoverMeaning();
            }
        }


        // --- 初始化 ---
        document.addEventListener('DOMContentLoaded', loadFromLocalStorage);
    </script>
</body>
</html>
