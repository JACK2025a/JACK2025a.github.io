                DOM.uploadScreen.classList.remove('hidden');
            } else if (view === 'study') {
                DOM.studyScreen.classList.remove('hidden');
                DOM.statsPanel.classList.remove('hidden');
                updateReviewQueue(); 
            } else if (view === 'bank') {
                DOM.wordBankScreen.classList.remove('hidden');
                DOM.statsPanel.classList.remove('hidden');
                DOM.toggleBankBtn.textContent = '📚 返回学习';
                updateWordBankUI(); // 现在错词本页也用于管理所有词汇
            } else if (view === 'stats') {
                DOM.statsPanel.classList.remove('hidden');
                updateStats();
            } else if (view === 'settings') {
                DOM.settingsPanel.classList.remove('hidden');
                renderKeyBindingsTable(); 
            }
        }
        
        function getWrongWords() {
            return wordList.filter(w => w.isWrong && !w.mastered);
        }

        function getMasteredWords() {
            return wordList.filter(w => w.mastered);
        }

        function updateWordBankUI() {
            const wrongWords = getWrongWords();
            const masteredWords = getMasteredWords();

            DOM.wordBankContent.innerHTML = '';
            
            if (wordList.length === 0) {
                DOM.bankEmptyMessage.classList.remove('hidden');
                DOM.startBankReviewBtn.classList.add('hidden');
                DOM.clearBankBtn.classList.add('hidden');
                return;
            }

            DOM.bankEmptyMessage.classList.add('hidden');
            DOM.startBankReviewBtn.classList.toggle('hidden', wrongWords.length === 0);
            DOM.clearBankBtn.classList.toggle('hidden', wrongWords.length === 0);
            
            // --- 错词列表 ---
            let wrongHtml = '<div class="word-list-section"><h3>❌ 仍需学习/错词本 (' + wrongWords.length + ' 词)</h3>';
            if (wrongWords.length > 0) {
                wrongWords.forEach(w => {
                    wrongHtml += `
                        <div class="word-bank-item">
                            <div class="word-bank-details">
                                <div class="word">${w.word}</div>
                                <div class="meaning">${w.meaning}</div>
                            </div>
                            <button class="btn btn-danger" style="padding: 8px 15px;" data-word="${w.word}" onclick="removeWordFromBank('${w.word}')">移出错词本</button>
                        </div>
                    `;
                });
            } else {
                 wrongHtml += '<p style="color:var(--secondary-text);">太棒了！错词本中没有需要优先复习的词汇。</p>';
            }
            wrongHtml += '</div>';

            // --- 已标熟列表 ---
            let masteredHtml = '<div class="word-list-section"><h3>✅ 已永久标熟 (' + masteredWords.length + ' 词)</h3>';
            if (masteredWords.length > 0) {
                 masteredWords.forEach(w => {
                    masteredHtml += `
                        <div class="word-bank-item">
                            <div class="word-bank-details">
                                <div class="word">${w.word}</div>
                                <div class="meaning">${w.meaning}</div>
                            </div>
                            <button class="btn btn-warning" style="padding: 8px 15px;" data-word="${w.word}" onclick="unmasterIndividualWord('${w.word}')">找回/取消标熟</button>
                        </div>
                    `;
                 });
            } else {
                 masteredHtml += '<p style="color:var(--secondary-text);">目前还没有永久标熟的词汇。</p>';
            }
            masteredHtml += '</div>';

            DOM.wordBankContent.innerHTML = wrongHtml + masteredHtml;
        }
        
        // 全局函数：移出错词本 (只影响 isWrong 状态)
        window.removeWordFromBank = function(wordToRemove) {
            const word = wordList.find(w => w.word === wordToRemove);
            if (word) {
                word.isWrong = false;
                if (word.repetitions === 0) {
                    word.nextReviewDate = 0; // 如果还没开始过 SRS，设为立即复习
                }
                saveToLocalStorage();
                updateWordBankUI();
                updateReviewQueue();
                showToast(`已将 "${word.word}" 移出错词本。`);
            }
        }
        
        // V3.9：取消单个词的标熟状态 (Mastered -> Review)
        window.unmasterIndividualWord = function(wordToUnmaster) {
             if (!confirm(`确定要将 "${wordToUnmaster}" 重新加入学习队列吗？这将清空它的掌握状态。`)) {
                 return;
             }
             
             const word = wordList.find(w => w.word === wordToUnmaster);
             if (word) {
                 // 重置为初始状态，但不改变其他词汇数据
                 const initialState = getInitialState();
                 Object.keys(initialState).forEach(key => {
                     word[key] = initialState[key];
                 });

                 saveToLocalStorage();
                 updateWordBankUI(); // 刷新列表
                 updateReviewQueue(); // 重新计算队列
                 showToast(`"${word.word}" 已成功找回，请在学习界面复习！`);
             }
        }

        // --- 5. 键盘快捷键逻辑 ---
        
        function handleGlobalKeyPress(event) {
            // 忽略输入框内的按键，例如在文件上传或设置面板
            if (event.target.tagName === 'INPUT' || event.target.tagName === 'TEXTAREA') {
                return;
            }

            const key = event.key;
            const keyUpper = key.toUpperCase();
            
            // 1. 发音 (全局可用)
            if (KEY_BINDINGS.speak.keys.includes(keyUpper)) {
                 if (currentView === 'study' && currentWord) {
                     speakWord(currentWord.word);
                     event.preventDefault(); // 阻止任何可能的默认行为
                     return;
                 }
            }
            
            // 2. 学习阶段快捷键
            if (currentView === 'study' && currentWord) {
                 
                 // Phase 1: 认知
                 if (currentPhase === 'phase-1') {
                     // 检查 Kill 按钮锁定状态
                     if (isKillButtonLocked && KEY_BINDINGS.phase1_master.keys.includes(keyUpper)) {
                         showToast("Kill 按钮冷却中 (0.5s)，请勿连击。");
                         event.preventDefault();
                         return;
                     }
                     
                     if (KEY_BINDINGS.phase1_master.keys.includes(keyUpper)) {
                         DOM.p1MasterBtn.click();
                     } else if (KEY_BINDINGS.phase1_know.keys.includes(keyUpper) || key === 'ArrowRight') {
                         // 兼容 ArrowRight 按下“认识”
                         DOM.p1KnowBtn.click();
                     } else if (KEY_BINDINGS.phase1_dont_know.keys.includes(keyUpper) || key === 'ArrowLeft') {
                          // 兼容 ArrowLeft 按下“不认识”
                         DOM.p1DontKnowBtn.click();
                     } else {
                         return; 
                     }
                     event.preventDefault(); // 阻止 Phase 1 快捷键触发滚动等默认行为
                 } 
                 
                 // Phase 2: 测验 (使用 A/B/C/D 或 1/2/3/4)
                 else if (currentPhase === 'phase-2') {
                     
                     let optionIndex = -1;
                     
                     if (KEY_BINDINGS.quiz_option_1.keys.includes(keyUpper)) optionIndex = 0;
                     else if (KEY_BINDINGS.quiz_option_2.keys.includes(keyUpper)) optionIndex = 1;
                     else if (KEY_BINDINGS.quiz_option_3.keys.includes(keyUpper)) optionIndex = 2;
                     else if (KEY_BINDINGS.quiz_option_4.keys.includes(keyUpper)) optionIndex = 3;
                     
                     if (optionIndex !== -1) {
                         const buttons = DOM.quizOptionsContainer.querySelectorAll('.quiz-option');
                         if (buttons.length > optionIndex) {
                             buttons[optionIndex].click();
                             event.preventDefault(); // 阻止测验快捷键的默认行为
                         }
                     }
                 }
                 
                 // Phase 3: 确认/反馈
                 else if (currentPhase === 'full-card') {
                     const isFinalConfirmationVisible = !document.getElementById('final-confirmation').classList.contains('hidden');
                     
                     // 修复 Space 键滚动问题，且确保只在按钮可见时触发
                     if (KEY_BINDINGS.next_word.keys.includes(keyUpper) && !isFinalConfirmationVisible) {
                         DOM.nextWordBtn.click(); // 继续下一个
                     } else if (KEY_BINDINGS.p3_master.keys.includes(keyUpper) && isFinalConfirmationVisible) {
                         DOM.p3MasterBtn.click(); // 确认掌握
                     } else if (KEY_BINDINGS.p3_loop.keys.includes(keyUpper) && isFinalConfirmationVisible) {
                         DOM.p3LoopBtn.click(); // 仍需学习
                     } else {
                         return;
                     }
                     event.preventDefault(); // 阻止 Phase 3 快捷键触发滚动等默认行为
                 }
            }
        }
        
        // --- 6. 设置面板逻辑 (不变) ---

        function renderKeyBindingsTable() {
            DOM.keyBindingsTable.innerHTML = '';
            
            for (const keyId in KEY_BINDINGS) {
                const binding = KEY_BINDINGS[keyId];
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${DEFAULT_KEY_BINDINGS[keyId].description}</td>
                    <td>${DEFAULT_KEY_BINDINGS[keyId].keys.join(', ')}</td>
                    <td><input type="text" id="key-${keyId}" value="${binding.keys.join(', ')}" data-key-id="${keyId}"></td>
                `;
                DOM.keyBindingsTable.appendChild(row);
            }
            
            DOM.keyBindingsTable.querySelectorAll('input').forEach(input => {
                input.addEventListener('input', (e) => {
                    // 自动格式化：去除空格，并转大写
                    e.target.value = e.target.value.toUpperCase().replace(/\s/g, ''); 
                });
            });
        }

        DOM.saveSettingsBtn.onclick = () => {
            const newBindings = {};

            DOM.keyBindingsTable.querySelectorAll('input').forEach(input => {
                const keyId = input.dataset.keyId;
                const value = input.value.trim();
                
                // 按逗号分割，并过滤空值
                const keys = value.split(',').map(k => k.trim()).filter(k => k.length > 0); 
                
                newBindings[keyId] = { keys: keys };
            });

            // 更新全局 KEY_BINDINGS
            for(const keyId in newBindings) {
                KEY_BINDINGS[keyId].keys = newBindings[keyId].keys;
            }
            saveKeyBindings();
        };

