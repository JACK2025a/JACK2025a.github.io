        };


        // --- 7. 事件监听器 (部分不变) ---

        DOM.appTitle.onclick = () => {
            if (wordList.length > 0) {
                 showView('stats');
            } else {
                showView('upload');
            }
        };

        DOM.startStudyBtn.onclick = () => showView('study');
        DOM.manageWordbookBtn.onclick = () => showView('upload');
        DOM.toggleSettingsBtn.onclick = () => showView('settings');

        function handleFileUpload(keepMastered) {
