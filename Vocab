<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>自定义词库学习 - V4.1 修复版 (Space键滚动修复)</title>
    <link href="https://fonts.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        /* --- 样式变量和主题 --- */
        :root {
            /* Light Mode (Google Default) */
            --bg-color: #f1f3f4; 
            --card-bg: #ffffff;
            --text-color: #202124;
            --secondary-text: #5f6368;
            --border-color: #dadce0;
            --primary-color: #1a73e8; /* Google Blue */
            --success-color: #34a853; 
            --danger-color: #ea4335; 
            --warning-color: #fbbc04; /* Google Yellow for Warning */
            --shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06); 
        }

        [data-theme="dark"] {
            /* Dark Mode */
            --bg-color: #202124;
            --card-bg: #3c4043;
            --text-color: #e8eaed;
            --secondary-text: #9aa0a6;
            --border-color: #5f6368;
            --primary-color: #8ab4f8; 
            --success-color: #81c995; 
            --danger-color: #f28b82; 
            --warning-color: #fcd45c; 
        }

        /* --- 基础布局和排版 (PC 优化) --- */
        body {
            font-family: 'Roboto', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 40px 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            transition: background-color 0.3s;
        }

        header {
            width: 100%;
            max-width: 700px;
            padding: 0 20px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 {
            font-size: 1.8em;
            font-weight: 500;
            cursor: pointer;
        }

        main {
            width: 100%;
            max-width: 700px; 
            padding: 0 20px;
        }

        .container {
            background-color: var(--card-bg);
            padding: 30px;
            border-radius: 12px;
            box-shadow: var(--shadow);
            margin-bottom: 20px;
            transition: background-color 0.3s;
        }

        .hidden {
            display: none !important;
        }
        
        /* 统计卡片 */
        #stats-panel {
            padding: 30px;
        }
        #stat-card {
            display: flex;
            justify-content: space-around;
            padding: 15px 0;
            border-top: 1px solid var(--border-color);
            margin-top: 20px;
            font-size: 0.9em;
        }
        .stat-item {
            text-align: center;
            flex-grow: 1;
        }
        .stat-value {
            font-weight: 700;
            font-size: 1.2em;
            color: var(--primary-color);
        }
        
        /* 快捷键设置面板样式 */
        #settings-panel table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            margin-bottom: 20px;
        }
        #settings-panel th, #settings-panel td {
            border: 1px solid var(--border-color);
            padding: 10px;
            text-align: left;
        }
        #settings-panel th {
            background-color: var(--bg-color);
            font-weight: 500;
        }
        #settings-panel td input {
            width: 100px;
            padding: 5px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            background-color: var(--card-bg);
            color: var(--text-color);
        }

        /* --- 按钮和交互 (Material 风格) --- */
        .btn {
            padding: 12px 25px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 1em;
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            margin: 5px;
            font-weight: 500;
            box-sizing: border-box;
            width: auto; 
            min-width: 150px; 
            background-color: transparent;
            color: var(--text-color);
            flex-grow: 1; 
        }
        
        .action-buttons button {
            flex-grow: 1; 
            margin: 5px;
            min-width: 120px;
        }
        .action-buttons {
            display: flex;
            justify-content: space-around;
            margin-top: 30px;
            flex-wrap: wrap; 
        }
        
        .settings-action-buttons {
             display: flex;
             justify-content: center;
             margin-top: 15px;
             flex-wrap: wrap;
             gap: 15px;
        }
        .settings-action-buttons button {
             min-width: 200px;
        }

        /* Primary/Success/Danger 按钮现在有背景色和白色文字 */
        .btn-primary, .btn-success, .btn-danger, .btn-warning {
            color: white;
            border-color: transparent; 
        }
        .btn-primary { background-color: var(--primary-color); }
        .btn-success { background-color: var(--success-color); }
        .btn-danger { background-color: var(--danger-color); }
        .btn-warning { background-color: var(--warning-color); }

        .btn-success:hover, .btn-danger:hover, .btn-primary:hover, .btn-warning:hover { filter: brightness(1.1); }
        
        /* 头部按钮容器布局 */
        #header-buttons {
             display: flex;
             gap: 10px;
             flex-wrap: wrap;
             justify-content: flex-end;
        }
        #header-buttons .btn {
            padding: 8px 15px; 
            min-width: 0;
            flex-grow: 0;
        }


        /* Upload Screen 按钮布局 */
        #upload-buttons {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        #upload-buttons button {
             width: 48%;
             min-width: 180px;
        }

        /* --- 学习卡片 --- */
        #study-card-content {
            min-height: 250px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        #current-word-p1-container {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 30px;
        }

        #p1-word-text {
            font-size: 3.5em;
            font-weight: 700;
            cursor: pointer;
            margin-right: 15px; 
        }
        
        #speak-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--primary-color);
            font-size: 1.8em; 
            padding: 0;
            transition: color 0.2s;
            line-height: 1;
        }
        #speak-btn:hover {
            color: var(--success-color);
        }

        /* 阶段 2: 选择题 */
        .quiz-options {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            width: 100%;
        }

        .quiz-option {
            padding: 15px;
            text-align: left;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background-color: var(--card-bg);
            color: var(--text-color);
            transition: background-color 0.1s, box-shadow 0.1s;
        }
        .quiz-option:hover {
            background-color: var(--bg-color);
            box-shadow: var(--shadow);
        }
        
        /* 测验后的正确答案显示 */
        .quiz-correct {
            background-color: var(--success-color) !important;
            color: white !important;
            box-shadow: 0 0 10px rgba(52, 168, 83, 0.5);
            transition: background-color 0.3s;
        }
        .quiz-wrong {
            background-color: var(--danger-color) !important;
            color: white !important;
        }

        /* 完整卡片样式 */
        .full-card-display {
            text-align: left;
        }
        .meaning-box {
            background-color: var(--bg-color);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            color: var(--secondary-text);
        }
        .examples-list p {
            margin: 8px 0;
            color: var(--secondary-text);
        }
        .format-prompt { 
            background: var(--bg-color); 
            padding: 15px; 
            border-left: 5px solid var(--primary-color); 
            color: var(--text-color);
            font-size: 0.9em;
            margin-top: 20px;
        }
        
        /* --- 词库管理样式 (原错词本) --- */
        .word-list-section {
             margin-top: 20px;
             border-top: 1px solid var(--border-color);
             padding-top: 15px;
        }
        .word-list-section h3 {
             color: var(--primary-color);
             font-weight: 500;
             margin-top: 0;
        }
        .word-bank-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px dashed var(--border-color);
        }
        .word-bank-item:last-child { border-bottom: none; }
        .word-bank-details .word { font-weight: 700; font-size: 1.2em; }
        .word-bank-details .meaning { color: var(--secondary-text); font-size: 0.9em; }

        /* --- 悬停/Toast 提示框 --- */
        #hover-meaning {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: var(--card-bg);
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            z-index: 1000;
            max-width: 400px; 
            border: 2px solid var(--primary-color);
            text-align: left;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }
        #hover-meaning.show {
            opacity: 1;
            pointer-events: auto;
        }
        #hover-meaning h3 { margin-top: 0; color: var(--primary-color); }

        #toast {
            visibility: hidden;
            min-width: 250px;
            background-color: var(--text-color);
            color: var(--card-bg);
            text-align: center;
            border-radius: 8px;
            padding: 16px;
            position: fixed;
            z-index: 1001;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            font-size: 1em;
            box-shadow: var(--shadow);
        }

        #toast.show {
            visibility: visible;
            animation: fadein 0.5s, fadeout 0.5s 2.5s;
        }

        @keyframes fadein {
            from { bottom: 0; opacity: 0; }
            to { bottom: 30px; opacity: 1; }
        }

        @keyframes fadeout {
            from { bottom: 30px; opacity: 1; }
            to { bottom: 0; opacity: 0; }
        }
    </style>
</head>
<body data-theme="light">

    <header>
        <h1 id="app-title">📖 单词学习</h1>
        <div id="header-buttons">
             <button id="quick-reload-btn" class="btn" style="background-color: var(--success-color); color: white; border: none;">✨ 快速重载词库</button> 
            <button id="toggle-bank-btn" class="btn">📘 词库管理</button>
            <button id="manage-wordbook-btn" class="btn">📂 文件导入</button> 
            <button id="toggle-settings-btn" class="btn">⚙️ 设置</button>
            <button id="toggle-theme-btn" class="btn">🌙</button>
        </div>
    </header>

    <main>
        
        <section id="stats-panel" class="container hidden">
            <h2>📊 学习概览</h2>
            <div id="stat-card">
                <div class="stat-item">总词数: <div class="stat-value" id="stat-total">0</div></div>
                <div class="stat-item">已掌握: <div class="stat-value" id="stat-mastered">0</div></div>
                <div class="stat-item">掌握率: <div class="stat-value" id="stat-ratio">0%</div></div>
            </div>
            <div style="margin-top: 20px; text-align: center;">
                 <button id="start-study-btn" class="btn btn-primary hidden">开始/继续学习</button>
            </div>
        </section>

        <section id="settings-panel" class="container hidden">
             <h2>⚙️ 快捷键设置</h2>
             <p style="color: var(--secondary-text);">修改下方的按键，然后点击保存。按键不区分大小写，使用逗号分隔多个按键。</p>
             
             <table>
                 <thead>
                     <tr>
                         <th>功能</th>
                         <th>默认按键</th>
                         <th>自定义按键</th>
                     </tr>
                 </thead>
                 <tbody id="key-bindings-table">
                     </tbody>
             </table>
             <div class="action-buttons">
                 <button id="save-settings-btn" class="btn btn-primary">💾 保存设置</button>
                 <button id="reset-settings-btn" class="btn">↩️ 重置默认</button>
             </div>
             
             <h2 style="margin-top: 30px;">⚠️ 数据管理</h2>
             <p style="color: var(--secondary-text);">危险操作，请谨慎使用。</p>
             <div class="settings-action-buttons">
                 <button id="unmaster-all-btn" class="btn btn-warning">🔄 找回所有已标熟的词汇</button>
                 <button id="reset-all-btn" class="btn btn-danger">🔥 重置所有学习进度</button>
             </div>
        </section>

        <section id="upload-screen" class="container hidden">
            <h2>词库管理与导入</h2>
            <p>请选择一个 TXT 文件开始学习或重载词库。</p>
            <input type="file" id="file-input" accept=".txt" style="display: block; margin: 20px auto;">
            
            <p id="error-message" style="color: var(--danger-color); margin-top: 15px;" class="hidden"></p>

            <div id="upload-buttons">
                <button id="start-upload-btn" class="btn btn-primary">🔄 重载/替换词库</button>
                <button id="start-new-btn" class="btn">✨ 导入新词库 (保留已掌握)</button>
            </div>

            <div class="format-prompt">
                <strong>📝 词库格式提示:</strong>
                <p>TXT 格式要求: 英文单词 | 词性. 汉译 | 英文例句 | 中文例句</p>
                <p>示例：Bacterium | n. 细菌 | Bacterium is a single-celled microorganism. | 细菌是一种单细胞微生物。</p>
            </div>
        </section>

        <section id="study-screen" class="container hidden">
            <p id="word-progress" style="color: var(--secondary-text); margin-bottom: 20px;"></p>
            
            <div id="study-card-content">
                <div id="phase-1" class="study-phase">
                    <div id="current-word-p1-container">
                        <h2 id="p1-word-text" style="margin: 0;" title="悬停或长按查看释义"></h2>
                        <button id="speak-btn" aria-label="发音" title="点击发音 (Y)">🔊</button>
                    </div>
                    
                    <div class="action-buttons">
                        <button id="p1-master-btn" class="btn btn-primary">✅ 永久标熟 (K)</button>
                        <button id="p1-know-btn" class="btn btn-success">认识 (Q)</button>
                        <button id="p1-dont-know-btn" class="btn btn-danger">不认识 / 忘了 (E)</button>
                    </div>
                </div>

                <div id="phase-2" class="study-phase hidden" style="width: 100%;">
                    <p style="font-size: 1.1em; margin-bottom: 20px;">请选择 **<span id="word-for-quiz"></span>** 的释义：</p>
                    <div id="quiz-options" class="quiz-options"></div>
                </div>

                <div id="full-card" class="study-phase hidden full-card-display" style="width: 100%;">
                    <h2 id="current-word-full" style="text-align: center; margin-top: 0;"></h2>
                    <div class="meaning-box">
                        <p id="word-meaning"></p>
                    </div>
                    <div id="word-examples" class="examples-list"></div>
                    
                    <div id="final-confirmation" class="action-buttons hidden">
                         <button id="p3-master-btn" class="btn btn-success">✅ 已掌握 (Enter)</button>
                         <button id="p3-loop-btn" class="btn btn-danger">🔄 仍需学习 (Backspace)</button>
                    </div>

                    <div id="next-word-button-container" class="action-buttons hidden">
                         <button id="next-word-btn" class="btn btn-primary">继续下一个词 (Space / →)</button>
                    </div>
                </div>
            </div>
        </section>

        <section id="word-bank-screen" class="container hidden">
            <h2>📘 词库管理</h2>
            <div id="word-bank-content">
                <p id="bank-empty-message">词库是空的，请先导入文件。</p>
            </div>
            <div class="action-buttons">
                <button id="start-bank-review-btn" class="btn btn-primary hidden">开始复习错词</button>
                <button id="clear-bank-btn" class="btn btn-danger hidden">清空错词本</button>
            </div>
        </section>
    </main>
    
    <div id="hover-meaning" class="hidden">
        <h3 id="hover-word"></h3>
        <p id="hover-meaning-text"></p>
        <p style="font-size:0.9em; color:var(--secondary-text);" id="hover-examples-text"></p>
    </div>

    <div id="toast"></div>

    <script>
        /* --- JavaScript 核心逻辑 --- */
        
        // --- 核心配置：快捷键 ---
        const DEFAULT_KEY_BINDINGS = {
            'phase1_master': { description: '阶段 1: 永久标熟 (K)', keys: ['K'] },
            'phase1_know': { description: '阶段 1: 认识/进入测验 (Q)', keys: ['Q'] },
            'phase1_dont_know': { description: '阶段 1: 不认识/跳过 (E)', keys: ['E'] },
            'speak': { description: '发音 (Y)', keys: ['Y'] },
            'next_word': { description: '继续下一个 (P3) (Space / →)', keys: ['Space', 'ArrowRight'] }, 
            'p3_master': { description: '阶段 3: 确认掌握 (Enter)', keys: ['Enter'] },
            'p3_loop': { description: '阶段 3: 仍需学习 (Backspace)', keys: ['Backspace'] },
            'quiz_option_1': { description: '测验选项 A (A/1)', keys: ['A', '1'] },
            'quiz_option_2': { description: '测验选项 B (B/2)', keys: ['B', '2'] },
            'quiz_option_3': { description: '测验选项 C (C/3)', keys: ['C', '3'] },
            'quiz_option_4': { description: '测验选项 D (D/4)', keys: ['D', '4'] },
        };
        
        let KEY_BINDINGS = { ...DEFAULT_KEY_BINDINGS };
        
        let wordList = [];
        let reviewQueue = [];
        let currentWordIndex = 0;
        let currentWord = null;
        let currentView = 'upload'; // 跟踪当前视图状态
        let currentPhase = ''; // 跟踪当前学习阶段
        let isKillButtonLocked = false; // V3.9: Kill 按钮锁定状态
        
        const storageKey = 'customWordListSRS_V3';
        const keyStorageKey = 'customKeyBindings_V3';
        const speaker = window.speechSynthesis;
        const DOM = {
            uploadScreen: document.getElementById('upload-screen'),
            studyScreen: document.getElementById('study-screen'),
            wordBankScreen: document.getElementById('word-bank-screen'),
            statsPanel: document.getElementById('stats-panel'),
            settingsPanel: document.getElementById('settings-panel'), 
            fileInput: document.getElementById('file-input'),
            errorMessage: document.getElementById('error-message'),
            wordProgress: document.getElementById('word-progress'),
            quizOptionsContainer: document.getElementById('quiz-options'),
            nextWordBtn: document.getElementById('next-word-btn'),
            toggleBankBtn: document.getElementById('toggle-bank-btn'),
            toggleThemeBtn: document.getElementById('toggle-theme-btn'),
            toggleSettingsBtn: document.getElementById('toggle-settings-btn'), 
            wordBankContent: document.getElementById('word-bank-content'),
            bankEmptyMessage: document.getElementById('bank-empty-message'),
            startBankReviewBtn: document.getElementById('start-bank-review-btn'),
            clearBankBtn: document.getElementById('clear-bank-btn'),
            currentWordP1Text: document.getElementById('p1-word-text'), 
            speakBtn: document.getElementById('speak-btn'),
            hoverMeaning: document.getElementById('hover-meaning'),
            appTitle: document.getElementById('app-title'),
            startUploadBtn: document.getElementById('start-upload-btn'),
            startNewBtn: document.getElementById('start-new-btn'),
            p1MasterBtn: document.getElementById('p1-master-btn'),
            p1KnowBtn: document.getElementById('p1-know-btn'), 
            p1DontKnowBtn: document.getElementById('p1-dont-know-btn'), 
            p3MasterBtn: document.getElementById('p3-master-btn'),
            p3LoopBtn: document.getElementById('p3-loop-btn'),
            quickReloadBtn: document.getElementById('quick-reload-btn'),
            manageWordbookBtn: document.getElementById('manage-wordbook-btn'),
            startStudyBtn: document.getElementById('start-study-btn'),
            keyBindingsTable: document.getElementById('key-bindings-table'), 
            saveSettingsBtn: document.getElementById('save-settings-btn'), 
            resetSettingsBtn: document.getElementById('reset-settings-btn'), 
            unmasterAllBtn: document.getElementById('unmaster-all-btn'), 
            resetAllBtn: document.getElementById('reset-all-btn'), 
        };

        // --- 0. 基础工具函数 ---

        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        function speakWord(word) {
            if (!speaker) {
                showToast("浏览器不支持 Web Speech API 发音功能。");
                return;
            }
            if (speaker.speaking) speaker.cancel();
            const utterance = new SpeechSynthesisUtterance(word);
            utterance.lang = 'en-US'; 
            speaker.speak(utterance);
        }
        
        function getInitialState() {
            // 返回一个干净的初始状态对象
            return {
                correctCount: 0,
                mastered: false, 
                isWrong: false,
                easeFactor: 2.5,
                interval: 0,
                repetitions: 0,
                nextReviewDate: 0 
            };
        }

        // --- 1. 数据模型和本地存储 ---

        function loadKeyBindings() {
            const savedBindings = localStorage.getItem(keyStorageKey);
            if (savedBindings) {
                const loaded = JSON.parse(savedBindings);
                KEY_BINDINGS = { ...DEFAULT_KEY_BINDINGS }; 
                for (const key in loaded) {
                    if (KEY_BINDINGS[key]) {
                        // 确保加载进来的按键也是大写，方便后续判断
                        KEY_BINDINGS[key].keys = loaded[key].keys.map(k => k.toUpperCase());
                    }
                }
            } else {
                 KEY_BINDINGS = { ...DEFAULT_KEY_BINDINGS };
            }
        }
        
        function saveKeyBindings() {
            const dataToSave = {};
            for (const key in KEY_BINDINGS) {
                dataToSave[key] = { keys: KEY_BINDINGS[key].keys };
            }
            localStorage.setItem(keyStorageKey, JSON.stringify(dataToSave));
            showToast("快捷键设置已保存！");
        }

        function loadFromLocalStorage() {
            loadKeyBindings(); 
            
            const data = localStorage.getItem(storageKey);
            if (data) {
                const loadedList = JSON.parse(data);
                // 使用扩展运算符和 getInitialState 确保加载的单词有 V4.1 版本所需的全部属性
                wordList = loadedList.map(word => ({ ...getInitialState(), ...word }));
                
                showView('stats');
                updateReviewQueue();
                updateWordBankUI();
                updateStats();
                showToast(`已从本地加载 ${wordList.length} 个单词。`);
            } else {
                showView('upload');
            }
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.body.setAttribute('data-theme', savedTheme);
            DOM.toggleThemeBtn.textContent = savedTheme === 'dark' ? '☀️' : '🌙';
        }

        function saveToLocalStorage() {
            localStorage.setItem(storageKey, JSON.stringify(wordList));
            updateStats();
        }
        
        function updateStats() {
            const total = wordList.length;
            const mastered = wordList.filter(w => w.mastered).length;
            const ratio = total > 0 ? ((mastered / total) * 100).toFixed(1) : 0;

            document.getElementById('stat-total').textContent = total;
            document.getElementById('stat-mastered').textContent = mastered;
            document.getElementById('stat-ratio').textContent = `${ratio}%`;
            
            DOM.startStudyBtn.classList.toggle('hidden', total === mastered); 
            
            if (currentView === 'stats') {
                 DOM.startStudyBtn.textContent = reviewQueue.length > 0 ? "继续学习" : "开始学习";
            }
        }


        // --- 2. 文件解析和 SRS 算法 ---
        
        function parseTxtContent(textContent) {
            const lines = textContent.trim().split('\n').map(line => line.trim()).filter(line => line.length > 0);
            const newWords = [];

            lines.forEach((line, id) => {
                const parts = line.split(' | ').map(p => p.trim());
                if (parts.length >= 4) {
                    newWords.push({
                        ...getInitialState(),
                        id: 'W' + Date.now() + '-' + (id + 1), 
                        word: parts[0],
                        meaning: parts[1],
                        example_en: parts[2],
                        example_zh: parts[3],
                    });
                }
            });
            return newWords;
        }

        function updateSRS(word, quality) {
            if (quality === 5) {
                 word.mastered = true; 
                 word.isWrong = false; 
                 word.interval = Infinity; 
                 return; 
            }
            
            if (quality < 3) {
                word.repetitions = 0;
                word.interval = 0;
                word.easeFactor = Math.max(1.3, word.easeFactor - 0.2);
                word.isWrong = true; 
            } else {
                word.repetitions++;
                word.easeFactor += (0.1 - (5 - quality) * (0.08 + (5 - quality) * 0.02));
                word.easeFactor = Math.max(1.3, word.easeFactor);

                if (word.repetitions === 1) {
                    word.interval = 1;
                } else if (word.repetitions === 2) {
                    word.interval = 6;
                } else {
                    word.interval = Math.round(word.interval * word.easeFactor);
                }
                word.isWrong = false;
            }

            const now = new Date();
            const nextReview = new Date(now.setDate(now.getDate() + word.interval));
            word.nextReviewDate = nextReview.getTime();
        }

        function updateReviewQueue() {
            const now = Date.now();
            reviewQueue = wordList
                .filter(w => !w.mastered) 
                .filter(w => w.nextReviewDate <= now)
                .sort((a, b) => a.nextReviewDate - b.nextReviewDate);

            DOM.wordProgress.textContent = `待复习/学习：${reviewQueue.length} 词`;

            const totalUnmastered = wordList.filter(w => !w.mastered).length;
            if (reviewQueue.length === 0 && totalUnmastered > 0) {
                 DOM.wordProgress.textContent += "。今日复习任务已完成！";
            } else if (reviewQueue.length === 0 && wordList.length > 0) {
                 DOM.wordProgress.textContent = "恭喜！所有单词已掌握！";
            }
            
            currentWordIndex = 0;
            if (reviewQueue.length > 0 && currentView === 'study') {
                switchPhase('phase-1');
            } else if (wordList.length > 0) {
                if(currentView === 'study') showView('stats'); 
            }
        }

        function handleWordbookImport(fileContent, keepMastered) {
            const newWords = parseTxtContent(fileContent);

            if (newWords.length === 0) {
                DOM.errorMessage.textContent = '文件内容为空或格式不正确。';
                DOM.errorMessage.classList.remove('hidden');
                return;
            }
            
            let finalWordList = newWords;

            if (keepMastered && wordList.length > 0) {
                const oldStateMap = new Map();
                wordList.forEach(w => oldStateMap.set(w.word, w));
                
                finalWordList = newWords.map(newWord => {
                    const existingState = oldStateMap.get(newWord.word);
                    if (existingState) {
                        return { 
                            ...newWord, 
                            ...existingState,
                            meaning: newWord.meaning,
                            example_en: newWord.example_en,
                            example_zh: newWord.example_zh,
                            id: newWord.id,
                        };
                    }
                    return newWord;
                });
            }

            wordList = finalWordList;
            saveToLocalStorage();
            showView('stats'); 
            showToast(`成功导入 ${wordList.length} 个单词，其中 ${wordList.filter(w => w.mastered).length} 个已掌握。`);
            updateReviewQueue();
        }


        // --- 3. 学习界面和三阶段逻辑 ---

        function switchPhase(targetPhaseId) {
            document.querySelectorAll('.study-phase').forEach(el => el.classList.add('hidden'));
            document.getElementById(targetPhaseId).classList.remove('hidden');
            currentPhase = targetPhaseId; 
            updateStudyUI(targetPhaseId);
        }

        function generateQuizOptions() {
            const correctMeaning = currentWord.meaning.split('；')[0];
            const correctOption = { text: correctMeaning, isCorrect: true };
            
            const wrongOptions = wordList
                .filter(w => w.word !== currentWord.word && w.meaning !== correctMeaning)
                .sort(() => 0.5 - Math.random())
                .slice(0, 3)
                .map(w => ({ text: w.meaning.split('；')[0], isCorrect: false }));

            let options = [correctOption, ...wrongOptions];
             while (options.length < 4) { options.push({ text: '---', isCorrect: false }); }
            
            return options.sort(() => 0.5 - Math.random());
        }

        function updateStudyUI(phaseId) {
            if (reviewQueue.length === 0) return;

            currentWord = reviewQueue[currentWordIndex];
            DOM.wordProgress.textContent = `待复习/学习：${reviewQueue.length} 词 (当前第 ${currentWordIndex + 1} 个)`;

            const fullWord = currentWord.word;
            document.getElementById('current-word-full').textContent = fullWord;
            document.getElementById('word-meaning').textContent = currentWord.meaning;
            document.getElementById('word-examples').innerHTML = `
                <p>英文例句: ${currentWord.example_en}</p>
                <p>中文翻译: ${currentWord.example_zh}</p>
            `;
            
            // Phase 1 
            if (phaseId === 'phase-1') {
                DOM.currentWordP1Text.textContent = fullWord;
                DOM.speakBtn.onclick = () => speakWord(fullWord);
                // V3.9: 确保按钮未锁定
                DOM.p1MasterBtn.disabled = isKillButtonLocked;
            } 
            // Phase 2
            else if (phaseId === 'phase-2') {
                document.getElementById('word-for-quiz').textContent = fullWord;
                
                const options = generateQuizOptions();
                const quizKeys = ['A', 'B', 'C', 'D']; // 测验快捷键提示
                DOM.quizOptionsContainer.innerHTML = options.map((opt, i) => `
                    <button class="quiz-option btn" data-correct="${opt.isCorrect}" data-key="${i + 1}">
                        <span style="font-weight: bold;">${quizKeys[i]}</span>. ${opt.text}
                    </button>
                `).join('');

                document.querySelectorAll('.quiz-option').forEach(btn => {
                    btn.onclick = handleQuizAnswer;
                });
            } 
            // Phase 3 & Feedback
            else if (phaseId === 'full-card') {
                // 只有当 correctCount >= 2 时，才显示最终的掌握/回队列按钮
                const isFinalPhase = currentWord.correctCount >= 2;
                document.getElementById('final-confirmation').classList.toggle('hidden', !isFinalPhase);
                document.getElementById('next-word-button-container').classList.toggle('hidden', isFinalPhase);
                
                // 确保 nextWordBtn 的点击事件是最新的
                DOM.nextWordBtn.onclick = () => goToNextWord();
            }
        }

        function goToNextWord() {
            currentWordIndex++;
            if (currentWordIndex >= reviewQueue.length) {
                updateReviewQueue();
                if (reviewQueue.length === 0) {
                     const totalUnmastered = wordList.filter(w => !w.mastered).length;
                     if (totalUnmastered > 0) {
                         showToast("今日复习任务已全部完成！");
                     } else if (wordList.length > 0) {
                         showToast("恭喜！所有单词已掌握！");
                     }
                     showView('stats');
                     return;
                }
            }
            switchPhase('phase-1');
        }

