<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>古诗 · 沉浸背诵</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;900&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        /* --- 核心变量定义 --- */
        :root {
            --bg-gradient: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            --card-bg: #ffffff;
            --text-primary: #2c3e50;
            --text-secondary: #7f8c8d;
            --mask-color: #e0e6ed;
            --accent-color: #1a73e8;
            --accent-hover: #1557b0;
            --btn-secondary-bg: #f1f3f4;
            --btn-secondary-text: #5f6368;
            --font-poem: 'Noto Serif SC', 'Songti SC', serif;
            --transition-curve: cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background: var(--bg-gradient);
            font-family: 'Roboto', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            user-select: none;
        }

        /* --- 主容器：悬浮卡片效果 --- */
        .app-container {
            width: 90%;
            max-width: 800px;
            height: 85vh;
            background: var(--card-bg);
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.08), 0 5px 15px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
            transition: all 0.5s ease;
        }

        /* --- 顶部进度条 --- */
        .progress-bar-container {
            height: 4px;
            width: 100%;
            background: #f0f0f0;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 100;
        }
        
        .progress-fill {
            height: 100%;
            background: var(--accent-color);
            width: 0%;
            transition: width 0.4s ease;
            box-shadow: 0 0 10px rgba(26, 115, 232, 0.4);
        }

        /* --- 导入界面 (Setup) --- */
        #setup-view {
            padding: 40px;
            display: flex;
            flex-direction: column;
            height: 100%;
            box-sizing: border-box;
            opacity: 1;
            transition: opacity 0.4s ease;
        }

        .title {
            font-family: var(--font-poem);
            font-size: 28px;
            color: var(--text-primary);
            margin-bottom: 10px;
            font-weight: 900;
            letter-spacing: 2px;
        }

        .subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 25px;
        }

        .input-wrapper {
            flex-grow: 1;
            position: relative;
            border-radius: 16px;
            border: 2px solid #edf2f7;
            background: #fcfcfc;
            transition: border-color 0.3s;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .input-wrapper:focus-within {
            border-color: var(--accent-color);
            background: #fff;
        }

        textarea {
            width: 100%;
            height: 100%;
            border: none;
            background: transparent;
            padding: 20px;
            font-family: var(--font-poem);
            font-size: 18px;
            line-height: 1.8;
            color: #444;
            resize: none;
            outline: none;
            box-sizing: border-box;
        }

        /* 按钮组 */
        .action-bar {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        /* 通用按钮样式 */
        .btn {
            padding: 14px 24px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.2s;
        }

        /* 开始按钮 (主) */
        .btn-primary {
            background: var(--accent-color);
            color: white;
            flex-grow: 2; /* 占据更多空间 */
            box-shadow: 0 4px 12px rgba(26, 115, 232, 0.3);
        }
        .btn-primary:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(26, 115, 232, 0.4);
        }

        /* 上传按钮 (次) */
        .btn-secondary {
            background: var(--btn-secondary-bg);
            color: var(--btn-secondary-text);
            flex-grow: 1;
        }
        .btn-secondary:hover {
            background: #e8eaed;
        }

        /* --- 背诵界面 (Stage) --- */
        #poem-view {
            display: none;
            height: 100%;
            overflow-y: auto;
            padding: 60px 20px;
            box-sizing: border-box;
            text-align: center;
            scroll-behavior: smooth;
            scrollbar-width: none;
        }
        #poem-view::-webkit-scrollbar {
            display: none;
        }

        .poem-line {
            position: relative;
            margin: 24px auto;
            display: inline-block;
            max-width: 90%;
        }

        .break {
            display: block;
            width: 100%;
            height: 0;
        }

        .text-content {
            font-family: var(--font-poem);
            font-size: 36px;
            color: var(--text-primary);
            letter-spacing: 0.1em;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }

        .is-title .text-content {
            font-size: 48px;
            font-weight: 900;
            color: #000;
        }
        .is-title {
            margin-bottom: 40px;
        }

        /* --- 遮罩层 --- */
        .mask {
            position: absolute;
            top: -5%;
            left: -5%;
            width: 110%;
            height: 110%;
            background: var(--mask-color);
            border-radius: 8px;
            cursor: pointer;
            z-index: 10;
            opacity: 1;
            transform: scale(1);
            filter: blur(0px);
            transition: all 0.6s var(--transition-curve);
        }

        .poem-line:hover .mask {
            background-color: #d1d9e6;
        }

        .poem-line.revealed .text-content {
            opacity: 1;
            transform: translateY(0);
        }

        .poem-line.revealed .mask {
            opacity: 0;
            transform: scale(1.15);
            filter: blur(12px);
            pointer-events: none;
        }

        .hint-overlay {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.05);
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            color: #999;
            pointer-events: none;
            opacity: 0;
            animation: fadeIn 2s 1s forwards;
        }

        .back-icon {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #fff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #555;
            font-size: 18px;
            z-index: 200;
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .app-container:hover .back-icon {
            opacity: 1;
        }

        @keyframes fadeIn {
            to { opacity: 1; }
        }

    </style>
</head>
<body>

    <div class="app-container">
        <div class="progress-bar-container">
            <div class="progress-fill" id="progress-fill"></div>
        </div>

        <div class="back-icon" onclick="resetApp()" title="重新导入">↺</div>

        <div id="setup-view">
            <div class="title">古诗背诵助手</div>
            <div class="subtitle">极简 · 沉浸 · 优雅</div>
            
            <div class="input-wrapper">
                <textarea id="poem-input" placeholder="请粘贴文本，或点击下方按钮上传 TXT 文件...

床前明月光
疑是地上霜
举头望明月
低头思故乡"></textarea>
            </div>
            
            <div class="action-bar">
                <input type="file" id="file-upload" accept=".txt" style="display: none;">
                
                <label for="file-upload" class="btn btn-secondary">
                    📂 上传 TXT
                </label>
                
                <button class="btn btn-primary" onclick="startPoem()">
                    开始背诵
                </button>
            </div>
        </div>

        <div id="poem-view">
            </div>

        <div class="hint-overlay">
            右键 / → 下一句 &nbsp; | &nbsp; 左键 / ← 上一句
        </div>
    </div>

    <script>
        // DOM 元素
        const setupView = document.getElementById('setup-view');
        const poemView = document.getElementById('poem-view');
        const poemInput = document.getElementById('poem-input');
        const progressFill = document.getElementById('progress-fill');
        const fileUpload = document.getElementById('file-upload');

        let linesData = [];
        let currentIndex = -1;

        // --- 文件上传逻辑 (新增) ---
        fileUpload.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            
            // 当文件读取成功后
            reader.onload = function(e) {
                const text = e.target.result;
                poemInput.value = text;
                
                // 视觉反馈：闪烁一下边框表示成功
                const wrapper = document.querySelector('.input-wrapper');
                wrapper.style.borderColor = '#34a853'; // 绿色
                setTimeout(() => {
                    wrapper.style.borderColor = '#edf2f7'; // 恢复
                }, 500);
            };

            // 读取文件 (默认 UTF-8)
            reader.readAsText(file, 'UTF-8');
            
            // 重置 input 以便允许重复上传同名文件
            e.target.value = '';
        });

        // 初始化/重置
        function resetApp() {
            poemView.style.display = 'none';
            setupView.style.display = 'flex';
            progressFill.style.width = '0%';
            setupView.style.opacity = 0;
            setTimeout(() => setupView.style.opacity = 1, 50);
        }

        // 开始
        function startPoem() {
            const text = poemInput.value.trim();
            if(!text) {
                alert("请输入内容或上传 TXT 文件");
                return;
            }

            // 处理文本
            const rawLines = text.split('\n');
            linesData = [];
            
            rawLines.forEach(line => {
                if(line.trim().length > 0) {
                    linesData.push(line.trim());
                }
            });

            if(linesData.length === 0) return;

            renderPoem();

            setupView.style.opacity = 0;
            setTimeout(() => {
                setupView.style.display = 'none';
                poemView.style.display = 'block';
                poemView.style.opacity = 0;
                setTimeout(() => poemView.style.opacity = 1, 50);
            }, 400);

            currentIndex = -1;
            updateProgress();
        }

        // 渲染逻辑
        function renderPoem() {
            poemView.innerHTML = '';
            linesData.forEach((text, index) => {
                const lineContainer = document.createElement('div');
                lineContainer.className = 'poem-line';
                if(index === 0) lineContainer.classList.add('is-title');
                
                lineContainer.innerHTML = `
                    <div class="text-content">${text}</div>
                    <div class="mask"></div>
                `;

                poemView.appendChild(lineContainer);
                
                const br = document.createElement('div');
                br.className = 'break';
                poemView.appendChild(br);
            });
            
            const spacer = document.createElement('div');
            spacer.style.height = '100px';
            poemView.appendChild(spacer);
        }

        // 揭示
        function revealNext() {
            if(currentIndex < linesData.length - 1) {
                currentIndex++;
                const lines = document.querySelectorAll('.poem-line');
                const target = lines[currentIndex];
                
                target.classList.add('revealed');
                target.scrollIntoView({behavior: "smooth", block: "center"});
                updateProgress();
            }
        }

        // 隐藏
        function hidePrev() {
            if(currentIndex >= 0) {
                const lines = document.querySelectorAll('.poem-line');
                const target = lines[currentIndex];
                
                target.classList.remove('revealed');
                currentIndex--;
                
                if(currentIndex >= 0) {
                     lines[currentIndex].scrollIntoView({behavior: "smooth", block: "center"});
                } else {
                    poemView.scrollTo({top: 0, behavior: 'smooth'});
                }
                updateProgress();
            }
        }

        function updateProgress() {
            const pct = ((currentIndex + 1) / linesData.length) * 100;
            progressFill.style.width = `${pct}%`;
        }

        // 事件监听
        document.addEventListener('contextmenu', (e) => {
            if(poemView.style.display === 'block') {
                e.preventDefault();
                revealNext();
            }
        });

        document.addEventListener('click', (e) => {
            if(poemView.style.display === 'block' && !e.target.closest('.back-icon')) {
                if(e.button === 0) hidePrev();
            }
        });

        document.addEventListener('keydown', (e) => {
            if(poemView.style.display !== 'block') return;

            if(['ArrowRight', 'ArrowDown', ' ', 'Enter'].includes(e.key)) {
                e.preventDefault();
                revealNext();
            } else if(['ArrowLeft', 'ArrowUp', 'Backspace'].includes(e.key)) {
                e.preventDefault();
                hidePrev();
            }
        });

    </script>
</body>
</html>
